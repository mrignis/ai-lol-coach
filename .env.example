# ── Riot API ──────────────────────────────────────────────────────────
# Get a key at https://developer.riotgames.com  (dev keys expire every 24h)
# Leave empty until you paste a real key: a placeholder value would look
# "configured" to the app, and every Riot call would fail with 401 instead
# of the UI telling you the key is missing.
RIOT_API_KEY=

# ── Server ────────────────────────────────────────────────────────────
PORT=3000

# ── LLM coaching layer ────────────────────────────────────────────────
# Chain: groq (primary) -> gemini (fallback) -> localized template.
# Options: groq | gemini | none. Keys stay server-side.
LLM_PROVIDER=groq

# Free key from console.groq.com (1000 req/day). gpt-oss-120b is the
# smartest text model on Groq's free tier; Groq hosts no vision model.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Free key from aistudio.google.com. Used as text fallback AND for vision
# (screenshot analysis). NOT flash-latest — that alias resolves to
# gemini-3.5-flash whose free tier is only 20 req/day.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
