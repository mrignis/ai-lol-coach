# ── How keys work ─────────────────────────────────────────────────────
# The installer already talks to a hosted proxy (Cloudflare Worker) that
# holds all the real keys, so a normal install needs NOTHING here.
#
# Fill anything below only if you want to run your OWN backend (keys go
# straight to Riot/Groq/Gemini instead of through the proxy).

# ── Riot API ──────────────────────────────────────────────────────────
# https://developer.riotgames.com  (dev keys expire every 24h)
RIOT_API_KEY=

# ── Server ────────────────────────────────────────────────────────────
PORT=3000

# ── AI (direct mode) ──────────────────────────────────────────────────
# groq: free key from console.groq.com. gemini: free from aistudio.google.com.
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Proxy mode (optional) ─────────────────────────────────────────────
# Set BOTH to route every Riot/Groq/Gemini call through your own worker so
# the app carries no upstream keys. See worker/README for deploy steps.
# PROXY_URL=https://lol-coach.<your-subdomain>.workers.dev
# PROXY_TOKEN=your-shared-app-token
