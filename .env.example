# ── Riot API ──────────────────────────────────────────────────────────
# Get a key at https://developer.riotgames.com  (dev keys expire every 24h)
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────────────────
PORT=3000

# ── LLM coaching layer ────────────────────────────────────────────────
# Provider for the "3 things to fix" text. Options: ollama | groq | anthropic | none
# The key/endpoint stays server-side; the browser never sees it.
LLM_PROVIDER=ollama

# ollama (default) — free local cloud-qwen you already run (`ollama signin`).
# Backend runs locally so it can reach localhost:11434 directly.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:480b-cloud

# groq (optional) — swap to this for cleaner prose if you have a key
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
